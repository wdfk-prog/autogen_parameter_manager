/**
 * @file par_layout_static.h
 * @brief Declare the generated static layout contract.
 * @author wdfk-prog ()
 * @version 1.1
 * @date 2026-04-22
 *
 * @copyright Copyright (c) 2026
 *
 * @note :
 * @par Change Log:
 * Date       Version Author      Description
 * 2026-03-21 1.0     wdfk-prog   first version
 * 2026-04-22 1.1     wdfk-prog   add object-slot and object-pool contract fields
 */
#ifndef _PAR_LAYOUT_STATIC_H_
#define _PAR_LAYOUT_STATIC_H_

#include <stdint.h>

#include "def/par_def.h"

#ifdef __cplusplus
extern "C" {
#endif

/**
 * @brief Static layout contract template.
 *
 * @note Script layout mode is intentionally incompatible with older static
 * layout headers that do not provide object layout fields when object rows are
 * compiled in.
 * @note Script layout mode expects generated values for:
 * - PAR_LAYOUT_STATIC_COUNT8/16/32
 * - PAR_LAYOUT_STATIC_OFFSET_TABLE
 * - PAR_LAYOUT_STATIC_COUNTOBJ, PAR_LAYOUT_STATIC_OBJ_POOL_BYTES, and
 *   PAR_LAYOUT_STATIC_OBJECT_POOL_OFFSET_TABLE only when object rows are
 *   compiled in
 */
#define PAR_LAYOUT_STATIC_COUNT8         (0u)
#define PAR_LAYOUT_STATIC_COUNT16        (0u)
#define PAR_LAYOUT_STATIC_COUNT32        (0u)
#define PAR_LAYOUT_STATIC_COUNTOBJ       (0u)
#define PAR_LAYOUT_STATIC_OBJ_POOL_BYTES (0u)

/**
 * @brief Static scalar and object slot offset map generated by an external script.
 */
extern const uint16_t g_par_layout_static_offset[ePAR_NUM_OF];
#define PAR_LAYOUT_STATIC_OFFSET_TABLE (g_par_layout_static_offset)

/**
 * @brief Static object-pool byte offset map generated by an external script.
 * @details Required whenever object rows are compiled in and
 * PAR_LAYOUT_STATIC_COUNTOBJ is nonzero. Generated offsets must be contiguous
 * and follow parameter-table order because the runtime validates that layout at
 * startup.
 */
extern const uint32_t g_par_layout_static_object_pool_offset[ePAR_NUM_OF];
#define PAR_LAYOUT_STATIC_OBJECT_POOL_OFFSET_TABLE (g_par_layout_static_object_pool_offset)

#ifdef __cplusplus
}
#endif

#endif /* _PAR_LAYOUT_STATIC_H_ */
