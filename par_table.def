/* ============================================================================================================================= */
/*  OBJECT                                                                                                                       */
/* ============================================================================================================================= */

/* Bundled object rows are optional examples. Each row is guarded by its
 * type switch, so disabling that object type compiles the sample row out.
 * Keep production rows unguarded when the row is required and should
 * fail-fast if its type support is disabled.
 */

#if (1 == PAR_CFG_ENABLE_TYPE_STR)
PAR_ITEM_STR (ePAR_WIFI_SSID  , 50001, "WiFi SSID"            , 0U     , 32U       , ((par_obj_init_t){ .p_data = (const uint8_t *)"ap", .len = 2U })                                        , NULL  , ePAR_ACCESS_RW, ePAR_ROLE_ALL, ePAR_ROLE_ALL , 0    , "Fixed-capacity string stored in the shared object pool.")
#endif /* (1 == PAR_CFG_ENABLE_TYPE_STR) */

#if (1 == PAR_CFG_ENABLE_TYPE_BYTES)
PAR_ITEM_BYTES(ePAR_AES_KEY   , 50002, "AES Key"              , 16U    , 16U       , ((par_obj_init_t){ .p_data = (const uint8_t[]){ 0x00U, 0x11U, 0x22U, 0x33U, 0x44U, 0x55U, 0x66U, 0x77U, 0x88U, 0x99U, 0xAAU, 0xBBU, 0xCCU, 0xDDU, 0xEEU, 0xFFU }, .len = 16U }), NULL  , ePAR_ACCESS_RW, ePAR_ROLE_ALL, ePAR_ROLE_ALL , 0    , "Fixed-capacity raw byte-array stored in the shared object pool.")
#endif /* (1 == PAR_CFG_ENABLE_TYPE_BYTES) */

#if (1 == PAR_CFG_ENABLE_TYPE_ARR_U8)
PAR_ITEM_ARR_U8(ePAR_U8_LUT   , 50003, "U8 LUT"               , 4U     , 4U        , ((par_obj_init_t){ .p_data = (const uint8_t[]){ 1U, 2U, 3U, 4U }, .len = 4U })                                   , NULL  , ePAR_ACCESS_RW, ePAR_ROLE_ALL, ePAR_ROLE_ALL , 0    , "Fixed-size uint8 lookup table stored in the shared object pool.")
#endif /* (1 == PAR_CFG_ENABLE_TYPE_ARR_U8) */

#if (1 == PAR_CFG_ENABLE_TYPE_ARR_U16)
PAR_ITEM_ARR_U16(ePAR_U16_LUT , 50004, "U16 LUT"              , 3U     , 3U        , ((par_obj_init_t){ .p_data = (const uint8_t *)(const uint16_t[]){ 100U, 200U, 300U }, .len = (uint16_t)(3U * sizeof(uint16_t)) }), NULL  , ePAR_ACCESS_RW, ePAR_ROLE_ALL, ePAR_ROLE_ALL , 0    , "Fixed-size uint16 lookup table stored in the shared object pool.")
#endif /* (1 == PAR_CFG_ENABLE_TYPE_ARR_U16) */

#if (1 == PAR_CFG_ENABLE_TYPE_ARR_U32)
PAR_ITEM_ARR_U32(ePAR_U32_LUT , 50005, "U32 LUT"              , 2U     , 2U        , ((par_obj_init_t){ .p_data = (const uint8_t *)(const uint32_t[]){ 1000UL, 2000UL }, .len = (uint16_t)(2U * sizeof(uint32_t)) }), NULL  , ePAR_ACCESS_RW, ePAR_ROLE_ALL, ePAR_ROLE_ALL , 0    , "Fixed-size uint32 lookup table stored in the shared object pool.")
#endif /* (1 == PAR_CFG_ENABLE_TYPE_ARR_U32) */
